VARIABLES jour, mois, anees, bis_anees, v_jour, v_mois, v_date;
DEBUT   
    ECRIRE "Saisez le jour "
    LIRE jour
    ECRIRE "Saisez le mois "
    LIRE mois
    ECRIRE "Saisez l'année "
    LIRE anees

    v_jour= jour >= 1 ET jour <= 31
    v_mois= mois >= 1 ET mois <= 12
    bis_anees= ((anees % 400) OU ((anees % 4) ET !(anees % 100)))

    SI v_mois ALORS
        SI mois == 2 ALORS
            SI bis_anees ALORS
                v_jour= (jour >= 1 ET jour <= 29)
            SINON 
                v_jour= (jour >= 1 ET jour <= 28)
            FINSI
        SINON SI (mois == 4 OU mois == 6 OU mois == 9 OU mois == 11) ALORS
                v_jour= (jour >= 1 ET jour <= 30)
            SINON
                v_jour= (jour >= 1 ET jour <= 31)
            FINSI
        FINSI
    FINSI
    v_date= v_jour ET v_mois
    SI v_date ALORS
        ECRIRE "Votre date: " + jour + "/" + mois + "/" + anees + " est valide!"
    SINON 
        ECRIRE "Votre date est non valide!"
    FINSI
FIN

