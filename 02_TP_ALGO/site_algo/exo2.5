VARIABLES chevPart, chevPlay, enOrdre, enDesordre
DEBUT
    ECRIRE "Saisie le nombre de chevaux partants"
    LIRE chevPart
    ECRIRE "Saisie le nombre de chevaux joués"
    LIRE chevPlay

    enOrdre = 1
    POUR i=0 A i<chevPlay INCREMENT i++ FAIRE
        enOrdre *= (chevPart - i)
    FINPOUR

    enDesordre = enOrdre
    POUR i=1 A i<=chevPlay INCREMENT i++ FAIRE
        enDesordre /= i
    FINPOUR

    ECRIRE "Nos chances de gagner en désordre est 1:" + enDesordre + "<br>
            et nos chances de gagner dans le bon ordre est 1:" + enOrdre;
FIN