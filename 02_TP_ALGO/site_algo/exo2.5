3.1
VARIABLES numbre_user, number_positive, numbre_negative

DEBUT
    number_positive="Votre nomber est positif"
    numbre_negative="Votre nomber est negatif"
    ECRIRE "Saise un nombre: "
    LIRE numbre_user
    SI number_user >= 0 ALORS
    ECRIRE number_positive
    SINON
    ECRIRE numbre_negative
FIN




VARIABLES number_user

DEBUT
    ECRIRE "Saise un nombre: "
    LIRE number_user
    SI  number_user >= 0 ALORS
        ECRIRE "Votre nomber est positif"
    SINON
        ECRIRE "Votre nomber est negatif"
    FINSI
FIN





3.2

VARIABLES num_1, num_2

DEBUT
    ECRIRE "Saise un nombre: "
    LIRE num_1
    ECRIRE "Saise un deuxième nombre: "
    LIRE num_2
    SI (num_1 > 0 ET num_2 > 0) OU (num_1 < 0 ET num_2 < 0) ALORS 
        ECRIRE "Votre produit est positif"
    SINON SI (num_1 > 0 ET num_2 < 0) OU (num_1 < 0 ET num_2 > 0) ALORS
        ECRIRE "Votre produit est negatif"
    FINSI
FIN




3.3

VARIABLES nom_1, nom_2, nom_3

DEBUT
    ECRIRE "Saise un nom: "
    LIRE nom_1
    ECRIRE "Saise deuxième nom: "
    LIRE nom_2
    ECRIRE "Saise troixième nom: "
    LIRE nom_3
    SI nom_1 <= nom_2 ET nom_2 <= nom_3 ALORS
        ECRIRE "Votre trois nom sont dans l’ordre alphabétique"
    SINON 
        ECRIRE "Votre trois nom ne sont pas dans l’ordre alphabétique"
    FINSI
FIN   



