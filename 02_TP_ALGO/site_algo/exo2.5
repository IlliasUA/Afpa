3.6

VARIABLES age, poussin, pupille, minime, cadet  

DEBUT
    ECRIRE "Saise l’âge d’un enfant: "
    LIRE age
    poussin = age > 5 ET age < 8
    pupille = age > 7 ET age < 10
    minime = age > 9 ET age < 12
    cadet = age >= 12
    SI poussin ALORS
        ECRIRE "Poussin de 6 à 7 ans "
    SINON SI pupille ALORS
        ECRIRE "Pupille de 8 à 9 ans"
    SINON SI minime ALORS
        ECRIRE "Minime de 10 à 11 ans"
    SINON SI cadet ALORS   
        ECRIRE "Cadet après 12 ans"
    SINON 
        ECRIRE "Saise l’âge a partir de 6 ans"
    FINSI
FIN



3.6(A)
VARIABLES age

DEBUT
    ECRIRE "Saisir l'âge d'un enfant : "
    LIRE age
    SI (age > 5) ET (age < 8) ALORS
        ECRIRE "Poussin de 6 à 7 ans"
    SINON SI (age > 7) ET (age < 10) ALORS
        ECRIRE "Pupille de 8 à 9 ans"
    SINON SI (age > 9) ET (age < 12) ALORS
        ECRIRE "Minime de 10 à 11 ans"
    SINON SI (age => 12) ALORS
        ECRIRE "Cadet après 12 ans"
    SINON
        ECRIRE "Saisir l'âge à partir de 6 ans"
    FINSI
FIN





4.1
VARIABLES tutu, toto

DEBUT
    ECRIRE "Saise Tutu"
    LIRE tutu
    ECRIRE "Saise Toto"
    LIRE toto
    ECRIRE "Saise Tata"
    LIRE tata
    SI tutu <= toto + 4 ET tata != "OK" ALORS
        tutu -= 1
    SINON  
        tutu += 1
    
    FINSI
    ECRIRE tutu
FIN 


4.2

VARIABLES heures_1, minutes_1

DEBUT 
    ECRIRE "Saise l’heur"
    LIRE heures_1
    ECRIRE "Saise minutes"
    LIRE minutes_1
    SI heures_1 != 23 ET minutes_1 != 59 ALORS
        minutes_1 += 1 
    SINON SI heures_1 != 23 ET minutes_1 == 59 ALORS
        heures_1 += 1
        minutes_1 = 0
    SINON 
        heures_1 = 0
        minutes_1 = 0
    FINSI 
    ECRIRE "Dans une minute, il sera ", heures_1, ": ", minutes_1
FIN  



4.2b

VARIABLES heures_1, minutes_1

DEBUT 
    ECRIRE "Saise l’heur"
    LIRE heures_1
    ECRIRE "Saise minutes"
    LIRE minutes_1
        minutes_1++
    SI minutes_1 == 60 ALORS
        minutes_1 = 0
        heures_1++
    SINON SI heures_1 == 24 ALORS
        heures_1 = 0
        minutes_1 = 0
    FINSI   
    ECRIRE "Dans une minute, il sera ", heures_1, ": ", minutes_1
FIN  


4.3

VARIABLES heures_1, minutes_1, secondes_1

DEBUT 
    ECRIRE "Saise l’heur"
    LIRE heures_1
    ECRIRE "Saise minutes"
    LIRE minutes_1
    ECRIRE "Saise secondes"
    LIRE secondes_1
        secondes_1++
    SI secondes_1 == 60 ALORS
        secondes_1 = 0
        minutes_1++
    SINON SI minutes_1 == 60 ALORS
        secondes_1 = 0
        minutes_1 = 0
        heures_1++
    SINON SI heures_1 == 24 ALORS
        secondes_1 = 0
        minutes_1 = 0
        heures_1 = 0
    FINSI    
    ECRIRE "Dans une seconde, il sera ", heures_1, ": ", minutes_1, ": ", secondes_1
FIN   


4.4 

VARIABLES  nombre_de_photocopies, facture

DEBUT
    ECRIRE "Saise nombre de photocopies"
    LIRE nombre_de_photocopies
    SI nombre_de_photocopies <= 10 ALORS
        facture = nombre_de_photocopies * 0.1
    SINON SI nombre_de_photocopies > 10 ET nombre_de_photocopies <= 30 ALORS
        facture = 10 * 0.1 + (nombre_de_photocopies - 10) * 0.09
    SINON SI nombre_de_photocopies > 30 ALORS
        facture = 10 * 0.1 + 20 * 0.09 + (nombre_de_photocopies - 30) * 0.08     
    FINSI
    ECRIRE "Votre facture est ", facture
FIN



