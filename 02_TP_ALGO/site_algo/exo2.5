    LIRE age
    ECRIRE "Depuis combien d'années avez-vous le permis? "
    LIRE annees_permi
    ECRIRE "Nombre d'accidents provoqués: "
    LIRE accident
    ECRIRE "Depuis combien d'années êtes-vous client? "
    LIRE aneess_client

    rouge = "Tarif rouge"
    orange = "Tarif orange"
    vert = "Tarif vert"
    blue = "Tarif blue"

    SI (age < 25 ET annees_permi < 2 ET accident == 0) OU 
        (age < 25 ET annees_permi >= 2 ET accident == 1) OU 
        (age >= 25 ET annees_permi < 2 ET accident == 1) OU 
        (age >= 25 ET annees_permi >= 2 ET accident == 2) ALORS
        ECRIRE rouge
    SINON SI (age < 25 ET annees_permi >= 2 ET accident == 0) OU 
        (age >= 25 ET annees_permi < 2 ET accident == 0) OU 
        (age >= 25 ET annees_permi >= 2 ET accident == 1) ALORS
        ECRIRE orange
    SINON SI (age >= 25 ET annees_permi >= 2 ET accident == 0) ALORS
        ECRIRE vert
    SINON
        ECRIRE "Refuse!"
    FINSI

    SI annees_client >= 5 ALORS
            SI rouge ALORS
                ECRIRE orange
            SINON SI orange ALORS
                ECRIRE vert
            SINON SI vert ALORS
                ECRIRE blue
            FINSI
        FINSI
    FINSI
FIN


