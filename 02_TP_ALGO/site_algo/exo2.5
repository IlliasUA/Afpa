VARIABLES  nombre_de_photocopies, facture

DEBUT
    ECRIRE "Saise nombre de photocopies"
    LIRE nombre_de_photocopies
    SI nombre_de_photocopies <= 10 ALORS
        facture = nombre_de_photocopies * 0.1
    SINON SI nombre_de_photocopies > 10 ET nombre_de_photocopies <= 30 ALORS
        facture = 10 * 0.1 + (nombre_de_photocopies - 10) * 0.09
    SINON SI nombre_de_photocopies > 30 ALORS
        facture = 10 * 0.1 + 20 * 0.09 + (nombre_de_photocopies - 30) * 0.08     
    FINSI
    ECRIRE "Votre facture est ", facture
FIN



