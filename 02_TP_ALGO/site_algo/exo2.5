5.10
VARIABLES sommeDonnee, sommeDevoir, votreMonnaie, resVotreMonnaie, nBillet10, nBillet5, nBillet1, resultates
DEBUT
    votreMonnaie = sommeDonnee - sommeDevoir
    resVotreMonnaie = votreMonnaie
    
    SI(votreMonnaie >= 10) ALORS
          TANTQUE (votreMonnaie >= 10) FAIRE
               nBillet10++;  
               votreMonnaie -= 10;
          FINTANTQUE
    SI(votreMonnaie >= 5) ALORS
          nBillet5++;
          votreMonnaie -= 5;
    FINSI
    SI(votreMonnaie >= 1) ALORS
          nBillet1 = votreMonnaie;
    FINSI
    
    resultates = `Votre monnaie est ${resVotreMonnaie}€: <br>`;

    SI(nBillet10 > 0) ALORS
          resultates += `- ${nBillet10} billet de 10€<br>`;     
    FINSI
    SI(nBillet5 > 0) ALORS
          resultates += `- ${nBillet5} billet de 5€<br>`;
    FINSI
    SI(nBillet1 > 0) ALORS
          resultates += `- ${nBillet1} billet de 1€`;
    FINSI
    
    ECRIRE resultates

FIN

