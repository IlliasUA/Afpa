4.8(A)

VARIABLES jour, mois, annee, bis_annee v_jour, v_mois, v_annee

DEBUT
    ECRIRE "Saisez le jour: "
    LIRE jour
    ECRIRE "Saisez le mois: "
    LIRE mois
    ECRIRE "Saisez le annee: "
    LIRE annee

    bis_annee = (annee % 400 == 0) OU (annee % 4 == 0 ET !(annee % 100 == 0))
    
    v_jour = jour >= 1 ET jour <= 31
    v_mois = mois >= 1 ET mois <= 12

    SI (v_mois) ALORS
        SI (mois == 2) ALORS
            SI (bis_annee) ALORS
                    v_jour = jour >= 1 ET jour <= 29
            SINON SI 
                    v_jour = jour >= 1 ET jour <= 28
            FINSI
        SINON SI (mois == 4 OU mois == 6 OU mois == 9 OU mois == 11) ALORS
            v_jour = jour >= 1 ET jour <= 30
        FINSI
    FINSI

    SI (v_jour ET v_mois) ALORS
        ECRIRE "Votre date est valide"
    SINON
        ECRIRE "Votre date est NON valide"
    FINSI
FIN




