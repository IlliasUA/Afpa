4.6

VARIABLES score_1, score_2, score_3, score_4, votants

DEBUT
    ECRIRE "Saisie de score de candidat 1"
    LIRE score_1
    ECRIRE "Saisie de score de candidat 2"
    LIRE score_2
    ECRIRE "Saisie de score de candidat 3"
    LIRE score_3
    ECRIRE "Saisie de score de candidat 4"
    LIRE score_4

    votants = score_1 + score_2 + score_3 + score_4; 

    SI ((score_1 / votants) * 100 >= 12.5) ET ((score_1 / votants) * 100 <= 50) ALORS
        SI (score_1 > score_2 ET score_1 > score_3 ET score_1 > score_4) ALORS 
            ECRIRE "Votre candidat peut participier au second tour en tan que lider!"
        SINON SI (score_1 <= score_2 OU score_1 <= score_3 OU score_1 <= score_4) ALORS 
            ECRIRE "Votre candidat participe au second tour sans avoir été en tête"
        FINSI
    SINON SI (score_1 / votants) * 100 > 50 ALORS
        ECRIRE "Votre candidat est élu!"
    SINON  
        ECRIRE "Votre candidat est perdu"
    FINSI
FIN


