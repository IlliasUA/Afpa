4.2

VARIABLES heures_1, minutes_1

DEBUT 
    ECRIRE "Saise l’heur"
    LIRE heures_1
    ECRIRE "Saise minutes"
    LIRE minutes_1
    SI heures_1 != 23 ET minutes_1 != 59 ALORS
        minutes_1 += 1 
    SINON SI heures_1 != 23 ET minutes_1 == 59 ALORS
        heures_1 += 1
        minutes_1 = 0
    SINON 
        heures_1 = 0
        minutes_1 = 0
    FINSI 
    ECRIRE "Dans une minute, il sera ", heures_1, ": ", minutes_1
FIN  



4.2b

VARIABLES heures_1, minutes_1

DEBUT 
    ECRIRE "Saise l’heur"
    LIRE heures_1
    ECRIRE "Saise minutes"
    LIRE minutes_1
        minutes_1++
    SI minutes_1 == 60 ALORS
        minutes_1 = 0
        heures_1++
    SINON SI heures_1 == 24 ALORS
        heures_1 = 0
        minutes_1 = 0
    FINSI   
    ECRIRE "Dans une minute, il sera ", heures_1, ": ", minutes_1
FIN  


4.3

VARIABLES heures_1, minutes_1, secondes_1

DEBUT 
    ECRIRE "Saise l’heur"
    LIRE heures_1
    ECRIRE "Saise minutes"
    LIRE minutes_1
    ECRIRE "Saise secondes"
    LIRE secondes_1
        secondes_1++
    SI secondes_1 == 60 ALORS
        secondes_1 = 0
        minutes_1++
    SINON SI minutes_1 == 60 ALORS
        secondes_1 = 0
        minutes_1 = 0
        heures_1++
    SINON SI heures_1 == 24 ALORS
        secondes_1 = 0
        minutes_1 = 0
        heures_1 = 0
    FINSI    
    ECRIRE "Dans une seconde, il sera ", heures_1, ": ", minutes_1, ": ", secondes_1
FIN   


